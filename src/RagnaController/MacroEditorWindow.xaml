<Window x:Class="RagnaController.MacroEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Editor" Width="800" Height="650"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None"
        WindowStartupLocation="CenterOwner">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,25">
                <TextBlock Text="MACRO EDITOR" FontSize="26" FontWeight="Black" Foreground="#E5B842" Effect="{StaticResource NeonGlow}"/>
                <TextBlock x:Name="MacroInfo" Text="Edit macro steps and timing" FontSize="12" FontWeight="Bold" Foreground="#7D8B9E" Margin="0,5,0,0"/>
            </StackPanel>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#1A2030" BorderBrush="#2A3245" BorderThickness="0,0,0,1" CornerRadius="8,8,0,0" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="NAME:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#7D8B9E"/>
                            <Border Grid.Column="1" Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36">
                                <TextBox x:Name="NameText" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" VerticalContentAlignment="Center" FontSize="14"/>
                            </Border>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="LOOPS:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#7D8B9E" FontSize="12"/>
                                <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36" Width="60">
                                    <TextBox x:Name="LoopCountText" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" VerticalContentAlignment="Center" FontSize="14" Text="1" TextAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="DurationText" Text="DURATION: 0ms" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="#A1B0C5"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="StepsGrid" AutoGenerateColumns="False" CanUserAddRows="False" Background="Transparent" BorderThickness="0" RowBackground="Transparent" AlternatingRowBackground="#1A2030" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2A3245" HeadersVisibility="Column" SelectionMode="Single" Foreground="#F0F4F8" FontSize="13" Padding="10">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#121620"/>
                                <Setter Property="Foreground" Value="#7D8B9E"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#2A3245"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="TYPE" Binding="{Binding Type}" Width="120" IsReadOnly="True"/>
                            <DataGridTextColumn Header="KEY" Binding="{Binding Key}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="DELAY (MS)" Binding="{Binding DelayMs}" Width="*"/>
                            <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="↑" Width="36" Height="28" Margin="2" Style="{StaticResource ConsoleGhostBtn}" Click="BtnMoveUp_Click" Tag="{Binding}"/>
                                            <Button Content="↓" Width="36" Height="28" Margin="2" Style="{StaticResource ConsoleGhostBtn}" Click="BtnMoveDown_Click" Tag="{Binding}"/>
                                            <Button Content="✕" Width="36" Height="28" Margin="2" Style="{StaticResource ConsoleDangerBtn}" Click="BtnDeleteStep_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="#1A2030" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="Speed Up (×2)" Width="120" Height="36" Margin="0,0,10,0" Style="{StaticResource ConsoleGhostBtn}" Click="BtnSpeedUp_Click"/>
                            <Button Content="Slow Down (×2)" Width="130" Height="36" Margin="0,0,10,0" Style="{StaticResource ConsoleGhostBtn}" Click="BtnSlowDown_Click"/>
                            <Button Content="Optimize" Width="100" Height="36" Margin="0,0,20,0" Style="{StaticResource ConsoleGhostBtn}" Click="BtnOptimize_Click"/>
                            <Button Content="+ Add Step" Width="110" Height="36" Style="{StaticResource ConsoleGhostBtn}" Click="BtnAddStep_Click" Margin="0,0,10,0"/>
                            <Button Content="Preview" Width="100" Height="36" Style="{StaticResource ConsolePrimaryBtn}" Click="BtnPreview_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                <Button Content="SAVE CHANGES" Style="{StaticResource ConsolePrimaryBtn}" Width="150" Height="40" Margin="0,0,10,0" Click="BtnSave_Click"/>
                <Button Content="CANCEL" Style="{StaticResource ConsoleGhostBtn}" Width="100" Height="40" Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>