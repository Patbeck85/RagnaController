<Window x:Class="RagnaController.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RagnaController – Settings"
        Width="420" Height="520"
        MinWidth="380" MinHeight="460"
        Background="#0D1017"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border BorderBrush="#21262D" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Titlebar -->
            <Border Grid.Row="0" Background="#161B22">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" Foreground="#D4A832" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="SETTINGS" Foreground="#E6EDF3"
                                   FontWeight="Bold" FontSize="12"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click"
                            HorizontalAlignment="Right"
                            Width="28" Height="28" Padding="0"
                            Background="#161B22" BorderBrush="#21262D"
                            Foreground="#8B949E" FontSize="11"
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,16,20,16">

                    <!-- ── Sektion: Startup ── -->
                    <TextBlock Text="STARTUP" Foreground="#555E6A"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-start engine"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Engine starts automatically on launch"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkAutoStart" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start minimized"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Window starts in the taskbar"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkStartMinimized" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Start in mini mode"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Launches directly as a small overlay window"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkStartMiniMode" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="#21262D" Margin="0,12,0,16"/>

                    <!-- ── Sektion: Feedback ── -->
                    <TextBlock Text="FEEDBACK" Foreground="#555E6A"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Sound feedback"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="System sounds on status changes"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkSound" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Controller vibration"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Rumble on skill use and status changes"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkRumble" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="#21262D" Margin="0,12,0,16"/>

                    <!-- ── Sektion: Anzeige ── -->
                    <TextBlock Text="DISPLAY" Foreground="#555E6A"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Show stick visualization"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Live stick position display in the sidebar"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkControllerViz" Grid.Column="1"
                                  VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="#21262D" Margin="0,12,0,16"/>

                    <!-- ── Sektion: Log ── -->
                    <TextBlock Text="LOGGING" Foreground="#555E6A"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Log level"
                                       Foreground="#E6EDF3" FontSize="12"/>
                            <TextBlock Text="Detail level of log output"
                                       Foreground="#555E6A" FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbLogLevel" Grid.Column="1"
                                  Height="30" VerticalAlignment="Center"
                                  Background="#0D1017" Foreground="#E6EDF3"
                                  BorderBrush="#21262D" FontSize="11">
                            <ComboBoxItem Content="Debug" Tag="0"/>
                            <ComboBoxItem Content="Info"  Tag="1"/>
                            <ComboBoxItem Content="Warning" Tag="2"/>
                            <ComboBoxItem Content="Error" Tag="3"/>
                        </ComboBox>
                    </Grid>

                    <!-- Trennlinie -->
                    <Rectangle Height="1" Fill="#21262D" Margin="0,12,0,16"/>

                    <!-- ── Sektion: Info ── -->
                    <TextBlock Text="INFO" Foreground="#555E6A"
                               FontSize="9" FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="VERSION" Foreground="#555E6A" FontSize="9"/>
                            <TextBlock x:Name="LblVersion" Text="v1.0.0"
                                       Foreground="#D4A832"
                                       FontFamily="Consolas" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="SETTINGS" Foreground="#555E6A" FontSize="9"/>
                            <TextBlock x:Name="LblSettingsPath"
                                       Text="%AppData%\RagnaController"
                                       Foreground="#8B949E"
                                       FontFamily="Consolas" FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="LblSettingsPath_Click"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <Rectangle Grid.Row="2" Fill="#21262D"/>

            <!-- Footer Buttons -->
            <Border Grid.Row="3" Background="#161B22" Padding="16,0">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="↺ Reset"
                            Click="BtnReset_Click"
                            Height="32" Padding="12,0"
                            Background="#1A0A0A" BorderBrush="#553333"
                            Foreground="#AA5555" FontSize="11" Cursor="Hand"/>

                    <Button Grid.Column="2" Content="Cancel"
                            Click="BtnClose_Click"
                            Height="32" Padding="14,0"
                            Background="#161B22" BorderBrush="#21262D"
                            Foreground="#8B949E" FontSize="11" Cursor="Hand"/>

                    <Button Grid.Column="4" Content="✓  Save"
                            Click="BtnSave_Click"
                            Height="32" Padding="14,0"
                            Background="#0D2A1A" BorderBrush="#D4A832"
                            Foreground="#D4A832" FontWeight="Bold"
                            FontSize="11" Cursor="Hand"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
