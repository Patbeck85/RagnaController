<Window x:Class="RagnaController.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="440" Height="600"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="45"/><RowDefinition Height="*"/><RowDefinition Height="60"/></Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="GLOBAL SETTINGS" FontWeight="Bold" FontSize="12" Foreground="#E5B842" VerticalAlignment="Center" Effect="{StaticResource NeonGlow}"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <StackPanel Grid.Row="1" Margin="25">
                <Border Style="{StaticResource CardBorder}" Padding="20">
                    <StackPanel>
                        <CheckBox x:Name="ChkAutoStart"      Content="Auto-start Engine on Launch"         Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <CheckBox x:Name="ChkSound"          Content="Enable Sound Feedback"               Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <CheckBox x:Name="ChkRumble"         Content="Enable Controller Rumble"            Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                        <CheckBox x:Name="ChkStartInMiniMode" Content="Start in Mini-Mode"                 Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,25"/>
                        <CheckBox x:Name="ChkFocusLock"      Content="Pause Engine when RO is in Background" Foreground="#E5B842" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Prevents accidental input in Discord or browser when tabbed out." Foreground="#7D8B9E" FontSize="11" Margin="28,0,0,10" TextWrapping="Wrap"/>
                        <Grid Margin="28,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Game client:" Foreground="#A1B0C5" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TxtFocusProcess" Grid.Column="1" Text="ragexe" FontFamily="Consolas" FontSize="13" Height="32"/>
                            <Button Grid.Column="2" x:Name="BtnBrowseExe" Content="Browse…" Click="BtnBrowseExe_Click"
                                    Style="{StaticResource ConsoleGhostBtn}" Height="32" Padding="12,0" Margin="8,0,0,0"
                                    ToolTip="Select your RO client .exe — only the filename (without .exe) is stored"/>
                        </Grid>
                        <TextBlock Text="LOG LEVEL" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                        <ComboBox x:Name="LogLevelCombo" Style="{StaticResource DarkComboBox}" Height="36" FontSize="13">
                            <ComboBoxItem Content="Debug" Tag="0"/><ComboBoxItem Content="Info" Tag="1"/><ComboBoxItem Content="Warning" Tag="2"/><ComboBoxItem Content="Error" Tag="3"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="LblVersion" Foreground="#7D8B9E" FontSize="11" FontWeight="Bold" Margin="0,25,0,0" HorizontalAlignment="Center"/>
                <TextBlock x:Name="LblSettingsPath" Foreground="#3A8EFF" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,0" Cursor="Hand" MouseLeftButtonDown="LblSettingsPath_Click"/>
            </StackPanel>
            <Border Grid.Row="2" Background="#07090D" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="RESET TO DEFAULT" Click="BtnReset_Click" Style="{StaticResource ConsoleGhostBtn}" Width="140" Height="36" Margin="0,0,10,0"/>
                    <Button Content="SAVE &amp; CLOSE" Click="BtnSave_Click" Style="{StaticResource ConsolePrimaryBtn}" Width="130" Height="36"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>