<Window x:Class="RagnaController.ProfileLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Library" Width="850" Height="600"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="15,0">
                    <TextBlock Text="PROFILE LIBRARY" FontWeight="Bold" FontSize="12" Foreground="#E5B842" VerticalAlignment="Center" Effect="{StaticResource NeonGlow}"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0">
                        <TextBox x:Name="SearchBox" Height="34" Padding="10,8" TextChanged="SearchBox_TextChanged" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0"/>
                    </Border>
                    <ComboBox x:Name="FilterCombo" Grid.Column="1" Height="36" Style="{StaticResource DarkComboBox}" SelectedIndex="0" SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem Content="All Profiles"/>
                        <ComboBoxItem Content="Built-in Only"/>
                        <ComboBoxItem Content="Custom Only"/>
                        <ComboBoxItem Content="Melee"/>
                        <ComboBoxItem Content="Ranged"/>
                        <ComboBoxItem Content="Mage"/>
                        <ComboBoxItem Content="Support"/>
                    </ComboBox>
                    <TextBlock x:Name="ProfileCount" Grid.Column="2" Text="0 profiles" Foreground="#7D8B9E" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ProfilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardBorder}" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F4F8"/>
                                                <Border Background="#1A2030" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="BUILT-IN" FontSize="9" FontWeight="Bold" Foreground="#E5B842"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ClassTips}" FontSize="12" Foreground="#A1B0C5" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Class: " FontSize="11" FontWeight="Bold" Foreground="#7D8B9E"/>
                                                <TextBlock Text="{Binding Class}" FontSize="11" FontWeight="Bold" Foreground="#3A8EFF"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                                            <Button Content="Load"   Width="85" Height="32" Margin="0,0,0,8" Style="{StaticResource ConsolePrimaryBtn}" Click="BtnLoad_Click"   Tag="{Binding}"/>
                                            <Button Content="Export" Width="85" Height="32" Margin="0,0,0,8" Style="{StaticResource ConsoleGhostBtn}"  Click="BtnExport_Click" Tag="{Binding}"/>
                                            <Button Content="↑ Share" Width="85" Height="32" Margin="0,0,0,8" Style="{StaticResource ConsoleGhostBtn}" Click="BtnShare_Click"  Tag="{Binding}" ToolTip="Upload to GitHub Gist and get a share code"/>
                                            <Button Content="Delete" Width="85" Height="32" Style="{StaticResource ConsoleDangerBtn}" Click="BtnDelete_Click" Tag="{Binding}" Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
            <Border Grid.Row="2" BorderBrush="#2A3245" BorderThickness="0,1,0,0" Background="#07090D" CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button Content="New Profile" Style="{StaticResource ConsolePrimaryBtn}" Width="110" Height="36" Margin="0,0,10,0" Click="BtnNew_Click"/>
                    <Button Content="Import" Style="{StaticResource ConsoleGhostBtn}" Width="90" Height="36" Margin="0,0,10,0" Click="BtnImport_Click"/>
                    <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0" Height="36">
                        <TextBox x:Name="TxtShareCode" Width="90" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="8,0" FontFamily="Consolas" FontSize="13" VerticalContentAlignment="Center" ToolTip="Enter a share code (e.g. GX-A3F9) and click ↓ Download"/>
                    </Border>
                    <Button Content="↓ Download" Style="{StaticResource ConsoleGhostBtn}" Width="100" Height="36" Margin="0,0,10,0" Click="BtnDownload_Click" ToolTip="Download profile by share code"/>
                    <Button Content="Close" Style="{StaticResource ConsoleGhostBtn}" Width="80" Height="36" Click="BtnClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>