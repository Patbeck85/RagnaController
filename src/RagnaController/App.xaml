<Application x:Class="RagnaController.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RagnaController"
             ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Color Palette (Obsidian & Gold) -->
        <SolidColorBrush x:Key="GoldBrush"     Color="#E5B842"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#B88A1D"/>
        <SolidColorBrush x:Key="BG1"           Color="#080A0F"/>
        <SolidColorBrush x:Key="BG2"           Color="#121620"/>
        <SolidColorBrush x:Key="BG3"           Color="#1A2030"/>
        <SolidColorBrush x:Key="BG4"           Color="#2A3245"/>
        <SolidColorBrush x:Key="TextHi"        Color="#F0F4F8"/>
        <SolidColorBrush x:Key="TextMid"       Color="#A1B0C5"/>
        <SolidColorBrush x:Key="TextLow"       Color="#7D8B9E"/>

        <!-- Legacy aliases -->
        <SolidColorBrush x:Key="BG1Brush"      Color="#080A0F"/>
        <SolidColorBrush x:Key="BG2Brush"      Color="#121620"/>
        <SolidColorBrush x:Key="BG3Brush"      Color="#1A2030"/>
        <SolidColorBrush x:Key="BG4Brush"      Color="#2A3245"/>
        <SolidColorBrush x:Key="BorderBrush"   Color="#2A3245"/>
        <SolidColorBrush x:Key="TextHiBrush"   Color="#F0F4F8"/>
        <SolidColorBrush x:Key="TextMidBrush"  Color="#A1B0C5"/>
        <SolidColorBrush x:Key="TextLowBrush"  Color="#7D8B9E"/>
        <SolidColorBrush x:Key="NeonBrush"     Color="#E5B842"/>

        <LinearGradientBrush x:Key="WindowGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07090D" Offset="0"/>
            <GradientStop Color="#10141D" Offset="1"/>
        </LinearGradientBrush>
        
        <DropShadowEffect x:Key="NeonGlow" Color="#E5B842" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="10" ShadowDepth="4" Opacity="0.4" Direction="270"/>

        <!-- Core Styles -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#CC121620"/>
            <Setter Property="BorderBrush" Value="#2A3245"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="CaretBrush" Value="#E5B842"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bg" Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bg" Property="BorderBrush" Value="#E5B842"/>
                                <Setter TargetName="bg" Property="Effect" Value="{StaticResource NeonGlow}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary button (SICHERE TRIGGERS) -->
        <Style x:Key="ConsolePrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="#1A2030"/>
            <Setter Property="Foreground"      Value="#E5B842"/>
            <Setter Property="BorderBrush"     Value="#B88A1D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="15,6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252D40"/>
                                <Setter TargetName="bd" Property="Effect" Value="{StaticResource NeonGlow}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5B842"/>
                                <Setter Property="Foreground" Value="#080A0F"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button (SICHERE TRIGGERS) -->
        <Style x:Key="ConsoleGhostBtn" TargetType="Button" BasedOn="{StaticResource ConsolePrimaryBtn}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="#A1B0C5"/>
            <Setter Property="BorderBrush" Value="#2A3245"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter x:Name="txt" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2030"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#7D8B9E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A3245"/>
                                <Setter Property="Foreground" Value="#F0F4F8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status Buttons -->
        <Style x:Key="ConsoleDangerBtn" TargetType="Button" BasedOn="{StaticResource ConsolePrimaryBtn}">
            <Setter Property="Foreground" Value="#FF3A52"/>
            <Setter Property="BorderBrush" Value="#FF3A52"/>
        </Style>
        <Style x:Key="ConsoleInfoBtn" TargetType="Button" BasedOn="{StaticResource ConsoleGhostBtn}">
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#7D8B9E"/>
        </Style>
        <Style x:Key="ConsoleWarningBtn" TargetType="Button" BasedOn="{StaticResource ConsolePrimaryBtn}">
            <Setter Property="Foreground" Value="#E5B842"/>
            <Setter Property="BorderBrush" Value="#E5B842"/>
        </Style>

        <!-- Tab buttons -->
        <Style x:Key="TabButton" TargetType="Button" BasedOn="{StaticResource ConsoleGhostBtn}">
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource ConsolePrimaryBtn}">
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background"      Value="Transparent"/>
        </Style>

        <!-- Slider -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Border Height="4" Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="2" VerticalAlignment="Center" Margin="5,0"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="#E5B842" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{TemplateBinding Background}" CornerRadius="2" VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="thumb" Width="14" Height="14" Fill="#E5B842" Stroke="#121620" StrokeThickness="2" Cursor="Hand">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#E5B842" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumb" Property="Width" Value="16"/>
                                                        <Setter TargetName="thumb" Property="Height" Value="16"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Background="Transparent" BorderThickness="0">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"  Value="#121620"/>
            <Setter Property="Foreground"  Value="#F0F4F8"/>
            <Setter Property="BorderBrush" Value="#2A3245"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="tb" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Cursor="Hand">
                                            <Path Data="M0,0 L4,4 L8,0" Stroke="#7D8B9E" StrokeThickness="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#E5B842"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" Margin="10,0,30,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            <Popup IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#121620" BorderBrush="#E5B842" BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}" Margin="0,2,0,0" Effect="{StaticResource CardShadow}">
                                    <ScrollViewer MaxHeight="200">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="tb" Property="BorderBrush" Value="#E5B842"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Items -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#A1B0C5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A2030"/>
                                <Setter Property="Foreground" Value="#F0F4F8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#252D40"/>
                                <Setter Property="Foreground" Value="#E5B842"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="bd" Background="#2A3245" CornerRadius="4" Margin="2"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#7D8B9E"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#E5B842"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Checkbox -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F0F4F8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="18" Height="18" Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="4" VerticalAlignment="Center">
                                <Path x:Name="check" Data="M3,9 L7,13 L14,4" Stroke="#E5B842" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Hidden" Margin="1,1,0,0"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="BorderBrush" Value="#E5B842"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="#7D8B9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>