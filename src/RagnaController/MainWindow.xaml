<Window x:Class="RagnaController.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RagnaController" Width="1020" Height="700"
        MinWidth="800" MinHeight="560"
        Background="#0D1017"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        WindowStyle="None" AllowsTransparency="True">

    <Window.Resources>

        <SolidColorBrush x:Key="BrushBg"       Color="#0D1017"/>
        <SolidColorBrush x:Key="BrushPanel"    Color="#161B22"/>
        <SolidColorBrush x:Key="BrushBorder"   Color="#21262D"/>
        <SolidColorBrush x:Key="BrushGold"     Color="#D4A832"/>
        <SolidColorBrush x:Key="BrushLime"     Color="#39FF14"/>
        <SolidColorBrush x:Key="BrushTextDim"  Color="#555E6A"/>
        <SolidColorBrush x:Key="BrushTextMid"  Color="#8B949E"/>
        <SolidColorBrush x:Key="BrushTextHigh" Color="#E6EDF3"/>

        <!-- Globaler Button-Stil -->
        <Style TargetType="Button">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="Foreground"      Value="#8B949E"/>
            <Setter Property="BorderBrush"     Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1F2937"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#30363D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground"        Value="#D4A832"/>
            <Setter Property="Background"        Value="#21262D"/>
            <Setter Property="BorderThickness"   Value="0"/>
            <Setter Property="Height"            Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#161B22"/>
            <Setter Property="Foreground"      Value="#E6EDF3"/>
            <Setter Property="BorderBrush"     Value="#21262D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="12"/>
        </Style>

        <Style x:Key="TabButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Foreground"      Value="#555E6A"/>
            <Setter Property="Padding"         Value="12,6"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <Style x:Key="TabButtonActive" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Foreground"  Value="#D4A832"/>
            <Setter Property="BorderBrush" Value="#D4A832"/>
        </Style>

        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555E6A"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,8,0,2"/>
        </Style>

        <Style x:Key="SliderValue" TargetType="TextBlock">
            <Setter Property="Foreground"          Value="#E6EDF3"/>
            <Setter Property="FontSize"            Value="11"/>
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="MinWidth"            Value="42"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#555E6A"/>
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- Toolbar separator style -->
        <Style x:Key="ToolbarSeparator" TargetType="Separator">
            <Setter Property="Background" Value="#2A3140"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="4,4,4,4"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#21262D" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="56"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ── TITLEBAR ─────────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#161B22">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" Foreground="#D4A832" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="RAGNA" Foreground="#D4A832" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="CONTROLLER" Foreground="#E6EDF3" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        <TextBlock x:Name="AppVersionLabel" Text="v1.1.0" Foreground="#555E6A" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse x:Name="ControllerDot" Width="6" Height="6" Fill="#555E6A" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <Border x:Name="ControllerBadge" Background="#0D1F0D" CornerRadius="3" Padding="8,3" VerticalAlignment="Center" BorderThickness="0" BorderBrush="Transparent">
                            <TextBlock x:Name="ControllerStatusText" Text="NO CONTROLLER" Foreground="#555E6A" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock x:Name="StatusBattery" Text="" Foreground="#39FF14" FontSize="10" FontWeight="SemiBold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <Border x:Name="PrecisionBadge" Background="#1A1A00" CornerRadius="3" Padding="8,3" Margin="8,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="⊕ PRECISION" Foreground="#FFAA00" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="—" Click="BtnMinimize_Click" Width="32" Height="28" Padding="0"/>
                        <Button Content="✕" Click="BtnClose_Click" Width="32" Height="28" Padding="0" Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── CONTROLS ─────────────────────────────────────────────── -->
            <Border Grid.Row="1" Background="#0D1017">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BtnStart" Grid.Column="0"
                            Content="▶  START" Click="BtnStart_Click"
                            Width="100" Height="34"
                            Background="#0D2E0D" BorderBrush="#39FF14"
                            Foreground="#39FF14" FontWeight="Bold" FontSize="12"/>

                    <Button x:Name="BtnStop" Grid.Column="2"
                            Content="■  STOP" Click="BtnStop_Click"
                            Width="100" Height="34"
                            Background="#2E0D0D" BorderBrush="#FF4444"
                            Foreground="#FF4444" FontWeight="Bold" FontSize="12"/>

                    <ComboBox x:Name="ProfileCombo" Grid.Column="4"
                              Height="34" VerticalAlignment="Center"
                              DisplayMemberPath="Name"
                              SelectionChanged="ProfileCombo_SelectionChanged"/>

                    <!-- Toolbar: Fenster-Buttons -->
                    <StackPanel Grid.Column="6" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,0,0">
                        <Button Content="📚 Profile" Click="BtnLibrary_Click"
                                Height="28" Padding="8,3" Margin="0,0,4,0"
                                ToolTip="Profile Library (Load, Import, Export)"/>
                        <Button Content="🎮 Remap" Click="BtnRemap_Click"
                                Height="28" Padding="8,3" Margin="0,0,4,0"
                                ToolTip="Button-Mapping anpassen"/>
                        <Button Content="⏺ Macro" Click="BtnMacro_Click"
                                Height="28" Padding="8,3" Margin="0,0,4,0"
                                ToolTip="Makro aufnehmen und abspielen"/>
                        <Button Content="✨ Wizard" Click="BtnWizard_Click"
                                Height="28" Padding="8,3"
                                ToolTip="Create new profile"/>
                        <Rectangle Width="1" Fill="#21262D" Margin="6,6,6,6"/>
                        <Button Content="⚙ Settings" Click="BtnSettings_Click"
                                Height="28" Padding="8,3"
                                ToolTip="Settings"/>
                            <Separator Style="{StaticResource ToolbarSeparator}"/>
                            <TextBlock x:Name="BatteryLabel" Text="🔌 Wired"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextLowBrush}"
                                       Margin="4,0,0,0" ToolTip="Controller battery"/>
                    </StackPanel>

                    <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Speichern-Button -->
                        <Button x:Name="BtnSave"
                                Content="💾  SAVE" Click="BtnSave_Click"
                                Height="28" Padding="10,3"
                                Background="#1A2A0A" BorderBrush="#88AA44"
                                Foreground="#AADD66" FontSize="10" FontWeight="SemiBold"
                                Visibility="Collapsed" Margin="0,0,8,0"/>
                        <!-- MiniMode -->
                        <Button x:Name="BtnMini" Content="⊡" Click="BtnMini_Click"
                                Width="28" Height="28" Padding="0" ToolTip="Mini-Modus"/>
                        <!-- Engine Status -->
                        <Ellipse x:Name="EnginePulse" Width="10" Height="10" Fill="#555E6A"
                                 VerticalAlignment="Center" Margin="10,0,6,0"/>
                        <TextBlock x:Name="EngineStateLabel" Text="STOPPED"
                                   Foreground="#555E6A" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Grid.Row="2" Fill="#21262D"/>

            <!-- ── HAUPTBEREICH ──────────────────────────────────────────── -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#0D1017">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="14,12,14,12">

                            <TextBlock Text="STATUS" Style="{StaticResource SectionHeader}"/>

                            <Border x:Name="LayerBadge" Background="#0A1F2A" BorderBrush="#D4A832" BorderThickness="1" CornerRadius="4" Padding="0,6" Margin="0,0,0,10">
                                <TextBlock x:Name="LayerText" Text="BASE LAYER" HorizontalAlignment="Center" Foreground="#D4A832" FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                            </Border>

                            <!-- Stick-Visualisierung -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="LINKS" FontSize="8" Foreground="#555E6A" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                    <Grid Width="50" Height="50" HorizontalAlignment="Center">
                                        <Ellipse Fill="#161B22" Stroke="#21262D" StrokeThickness="1"/>
                                        <Line X1="25" Y1="8" X2="25" Y2="42" Stroke="#21262D" StrokeThickness="1"/>
                                        <Line X1="8" Y1="25" X2="42" Y2="25" Stroke="#21262D" StrokeThickness="1"/>
                                        <Canvas x:Name="LeftStickCanvas" Width="50" Height="50" ClipToBounds="True">
                                            <Ellipse x:Name="LeftStickDot" Width="10" Height="10" Fill="#D4A832" Canvas.Left="20" Canvas.Top="20"/>
                                        </Canvas>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="RECHTS" FontSize="8" Foreground="#555E6A" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                    <Grid Width="50" Height="50" HorizontalAlignment="Center">
                                        <Ellipse Fill="#161B22" Stroke="#21262D" StrokeThickness="1"/>
                                        <Line X1="25" Y1="8" X2="25" Y2="42" Stroke="#21262D" StrokeThickness="1"/>
                                        <Line X1="8" Y1="25" X2="42" Y2="25" Stroke="#21262D" StrokeThickness="1"/>
                                        <Canvas x:Name="RightStickCanvas" Width="50" Height="50" ClipToBounds="True">
                                            <Ellipse x:Name="RightStickDot" Width="10" Height="10" Fill="#FF8C00" Canvas.Left="20" Canvas.Top="20"/>
                                        </Canvas>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262D" Margin="0,0,0,10"/>

                            <!-- Bewegung -->
                            <TextBlock Text="BEWEGUNG" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="DEADZONE" Style="{StaticResource SideLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                <Slider x:Name="DeadzoneSlider" Grid.Column="0" Minimum="0.05" Maximum="0.40" ValueChanged="DeadzoneSlider_ValueChanged"/>
                                <TextBlock x:Name="DeadzoneValue" Grid.Column="2" Style="{StaticResource SliderValue}"/>
                            </Grid>

                            <TextBlock Text="KURVE" Style="{StaticResource SideLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                <Slider x:Name="CurveSlider" Grid.Column="0" Minimum="1.0" Maximum="3.0" ValueChanged="CurveSlider_ValueChanged"/>
                                <TextBlock x:Name="CurveValue" Grid.Column="2" Style="{StaticResource SliderValue}"/>
                            </Grid>

                            <TextBlock Text="GESCHWINDIGKEIT" Style="{StaticResource SideLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                <Slider x:Name="ActionSpeedSlider" Grid.Column="0" Minimum="1.0" Maximum="10.0" ValueChanged="ActionSpeedSlider_ValueChanged"/>
                                <TextBlock x:Name="ActionSpeedValue" Grid.Column="2" Style="{StaticResource SliderValue}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262D" Margin="0,10,0,10"/>

                            <!-- Cursor -->
                            <TextBlock Text="CURSOR" Style="{StaticResource SectionHeader}"/>

                            <TextBlock Text="MAX SPEED" Style="{StaticResource SideLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions>
                                <Slider x:Name="SensitivitySlider" Grid.Column="0" Minimum="400" Maximum="1800" ValueChanged="SensitivitySlider_ValueChanged"/>
                                <TextBlock x:Name="SensitivityValue" Grid.Column="2" Style="{StaticResource SliderValue}"/>
                            </Grid>

                            <Rectangle Height="1" Fill="#21262D" Margin="0,10,0,10"/>

                            <!-- Modi -->
                            <TextBlock Text="MODI" Style="{StaticResource SectionHeader}"/>

                            <Grid Margin="0,4,0,6">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Action RPG" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                                <Border x:Name="ToggleBg" Grid.Column="1" Width="40" Height="20" CornerRadius="10" Background="#21262D" BorderBrush="#30363D" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="MoveModeToggle_Click">
                                    <Ellipse x:Name="ToggleThumb" Width="14" Height="14" Fill="#555E6A" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Precision Mode" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center"/>
                                <Border x:Name="PrecisionIndicator" Grid.Column="1" Background="#1A1200" CornerRadius="3" Padding="6,2">
                                    <TextBlock x:Name="PrecisionLabel" Text="OFF" Foreground="#555E6A" FontSize="10" FontFamily="Consolas"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Rectangle Grid.Column="1" Fill="#21262D"/>

                <!-- RECHTS: Tabs + Panels -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab-Leiste -->
                    <Border Grid.Row="0" Background="#0D1017" Padding="10,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button x:Name="TabBtnBase"  Content="BASE" Style="{StaticResource TabButtonActive}" Click="TabBase_Click"/>
                            <Button x:Name="TabBtnL1"    Content="L1"   Style="{StaticResource TabButton}"       Click="TabL1_Click"  Margin="2,0,0,0"/>
                            <Button x:Name="TabBtnR1"    Content="R1"   Style="{StaticResource TabButton}"       Click="TabR1_Click"  Margin="2,0,0,0"/>
                            <Button x:Name="TabBtnL2"    Content="L2"   Style="{StaticResource TabButton}"       Click="TabL2_Click"  Margin="2,0,0,0"/>
                            <Button x:Name="TabBtnR2"    Content="R2"   Style="{StaticResource TabButton}"       Click="TabR2_Click"  Margin="2,0,0,0"/>
                            <Rectangle Width="1" Fill="#21262D" Margin="10,8,10,8"/>
                            <Button x:Name="TabBtnInfo"  Content="INFO" Style="{StaticResource TabButton}"       Click="TabInfo_Click" Foreground="#39FF14"/>
                            <Button x:Name="TabBtnLog"   Content="LOG"  Style="{StaticResource TabButton}"       Click="TabLog_Click"  Margin="2,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Rectangle Grid.Row="1" Fill="#21262D"/>

                    <!-- Panels -->
                    <Grid Grid.Row="2" Margin="14,12,14,12">

                        <ScrollViewer x:Name="PanelBase" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MappingsBase"/>
                        </ScrollViewer>

                        <ScrollViewer x:Name="PanelL1" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MappingsL1"/>
                        </ScrollViewer>

                        <ScrollViewer x:Name="PanelR1" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MappingsR1"/>
                        </ScrollViewer>

                        <ScrollViewer x:Name="PanelL2" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MappingsL2"/>
                        </ScrollViewer>

                        <ScrollViewer x:Name="PanelR2" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="MappingsR2"/>
                        </ScrollViewer>

                        <Border x:Name="PanelLog" Visibility="Collapsed" Background="#0A0E14">
                            <DockPanel>
                                <!-- Log Toolbar -->
                                <Border DockPanel.Dock="Top" Background="#0D1117"
                                        BorderBrush="#21262D" BorderThickness="0,0,0,1"
                                        Padding="6,4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="SESSION LOG" Foreground="#555E6A"
                                                   FontSize="9" FontWeight="Bold"
                                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="📋 Export" Click="BtnExportLog_Click"
                                                Height="22" Padding="8,2" FontSize="10"/>
                                        <Button Content="🗑 Clear" Click="BtnClearLog_Click"
                                                Height="22" Padding="8,2" FontSize="10" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <TextBlock x:Name="LogTextBlock" Foreground="#8B949E"
                                               FontFamily="Consolas" FontSize="11"
                                               TextWrapping="Wrap" Padding="8"/>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border x:Name="PanelInfo" Visibility="Collapsed" Background="#0A120A" BorderBrush="#1E3A1E" BorderThickness="1" CornerRadius="4">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16,14,16,14">

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock x:Name="InfoClassName" Text="STANDARD" FontSize="18" FontWeight="Bold" Foreground="#39FF14"/>
                                        <Border Background="#1A3A1A" CornerRadius="4" Padding="8,3" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock x:Name="InfoClassType" Text="MELEE" FontSize="10" Foreground="#88FF88" FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>

                                    <Rectangle Height="1" Fill="#1E3A1E" Margin="0,0,0,12"/>

                                    <TextBlock Text="CONTROLLER SETTINGS" Foreground="#3A5A3A" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="CURSOR SPEED" Foreground="#3A5A3A" FontSize="9"/>
                                            <TextBlock x:Name="InfoCursorSpeed" Text="1200 px/s" Foreground="#88FF88" FontSize="13" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="BEWEGUNG" Foreground="#3A5A3A" FontSize="9"/>
                                            <TextBlock x:Name="InfoActionSpeed" Text="5.0" Foreground="#88FF88" FontSize="13" FontFamily="Consolas"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="AUSLAUF" Foreground="#3A5A3A" FontSize="9"/>
                                            <TextBlock x:Name="InfoCoastFrames" Text="3 Frames" Foreground="#88FF88" FontSize="13" FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Grid>

                                    <Rectangle Height="1" Fill="#1E3A1E" Margin="0,0,0,12"/>

                                    <TextBlock Text="EMPFOHLENE F-TASTEN BELEGUNG" Foreground="#3A5A3A" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="InfoSkillList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0D1F0D" Margin="0,2" Padding="10,6" CornerRadius="3">
                                                    <TextBlock Text="{Binding}" Foreground="#CCFFCC" FontFamily="Consolas" FontSize="12"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Rectangle Height="1" Fill="#1E3A1E" Margin="0,12,0,12"/>

                                    <TextBlock Text="CONTROLLER TIPS" Foreground="#3A5A3A" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Border Background="#0D1A0D" Padding="12,10" CornerRadius="4" BorderBrush="#1E3A1E" BorderThickness="1">
                                        <TextBlock x:Name="InfoTips" Text="" Foreground="#AAFFAA" TextWrapping="Wrap" LineHeight="22" FontSize="12"/>
                                    </Border>

                                    <Rectangle Height="1" Fill="#1E3A1E" Margin="0,12,0,12"/>

                                    <TextBlock Text="STANDARD BUTTONS (all classes)" Foreground="#3A5A3A" FontSize="9" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="A        → Attack / LMB"  Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="B        → Enter / Dialog"  Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="X (Hold) → Alt – Items"     Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="Y        → Sitzen"          Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="L3       → Rechtsklick"     Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="R3       → Doppelklick"     Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="↑        → Tab (Ziel)"      Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="↓        → F1 Quick-Heal"   Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="Start    → Escape"          Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="Select   → Precision"       Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="L1+ABXY  → F1–F4"           Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                            <TextBlock Text="R2+ABXY  → Ctrl+F1–F4"      Foreground="#446644" FontFamily="Consolas" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </Grid>

            <Rectangle Grid.Row="4" Fill="#21262D"/>

            <!-- ── STATUSBAR ─────────────────────────────────────────────── -->
            <Border Grid.Row="5" Background="#161B22">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#FF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" Text="STOPPED" Foreground="#FF4444" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Width="1" Fill="#21262D" Margin="0,6"/>

                    <TextBlock x:Name="StatusProfile" Grid.Column="2" Text="–" Foreground="#8B949E" FontSize="10" VerticalAlignment="Center" Margin="12,0"/>

                    <Rectangle Grid.Column="3" Width="1" Fill="#21262D" Margin="0,6"/>

                    <TextBlock x:Name="StatusLayer" Grid.Column="4" Text="BASE" Foreground="#D4A832" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>

                    <Rectangle Grid.Column="5" Width="1" Fill="#21262D" Margin="0,6"/>

                    <TextBlock x:Name="StatusCursorSpeed" Grid.Column="6" Text="– px/s" Foreground="#555E6A" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>

                    <Rectangle Grid.Column="7" Width="1" Fill="#21262D" Margin="0,6"/>

                    <TextBlock x:Name="StatusPrecision" Grid.Column="8" Text="○ PRECISION OFF" Foreground="#555E6A" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>

                    <Rectangle Grid.Column="9" Width="1" Fill="#21262D" Margin="0,6"/>

                    <TextBlock x:Name="StatusSweep" Grid.Column="10" Text="◌ SWEEP OFF" Foreground="#555E6A" FontSize="10" FontFamily="Consolas" VerticalAlignment="Center" Margin="12,0"/>

                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
