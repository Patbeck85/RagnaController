<Window x:Class="RagnaController.ButtonRemappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Button Remapping" Width="1200" Height="850"
        Background="Transparent" Foreground="#F0F4F8"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="LayerButton" TargetType="Button" BasedOn="{StaticResource ConsoleGhostBtn}"><Setter Property="Height" Value="36"/><Setter Property="Margin" Value="2"/><Setter Property="FontSize" Value="12"/></Style>
        <Style x:Key="LayerButtonActive" TargetType="Button" BasedOn="{StaticResource ConsolePrimaryBtn}"><Setter Property="Height" Value="36"/><Setter Property="Margin" Value="2"/><Setter Property="FontSize" Value="12"/></Style>
    </Window.Resources>
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="*"/><RowDefinition Height="60"/></Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="🎮" Foreground="#E5B842" Margin="0,0,10,0" FontSize="16" Effect="{StaticResource NeonGlow}"/><TextBlock Text="BUTTON REMAPPING" FontWeight="Bold" FontSize="14" Foreground="#F0F4F8"/></StackPanel>
                    <Button Content="✕" Click="BtnCancel_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="25">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="440"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="25">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <TextBlock Text="CONTROLLER PREVIEW" FontSize="12" FontWeight="Black" Foreground="#E5B842" Margin="0,0,0,20" HorizontalAlignment="Center" Effect="{StaticResource NeonGlow}"/>
                        <Viewbox Grid.Row="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"><ContentControl x:Name="PreviewContainer"/></Viewbox>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20" Margin="15,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="SELECT LAYER" FontSize="12" FontWeight="Black" Foreground="#E5B842" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                            <UniformGrid Columns="5" HorizontalAlignment="Stretch">
                                <Button x:Name="LayerBase" Content="BASE" Click="LayerBtn_Click" Style="{StaticResource LayerButtonActive}" Tag=""/>
                                <Button x:Name="LayerL1" Content="L1" Click="LayerBtn_Click" Style="{StaticResource LayerButton}" Tag="L1+"/>
                                <Button x:Name="LayerR1" Content="R1" Click="LayerBtn_Click" Style="{StaticResource LayerButton}" Tag="R1+"/>
                                <Button x:Name="LayerL2" Content="L2" Click="LayerBtn_Click" Style="{StaticResource LayerButton}" Tag="L2+"/>
                                <Button x:Name="LayerR2" Content="R2" Click="LayerBtn_Click" Style="{StaticResource LayerButton}" Tag="R2+"/>
                            </UniformGrid>
                            <Rectangle Height="1" Fill="#2A3245" Margin="0,20,0,0"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="BUTTONS" FontSize="12" FontWeight="Bold" Foreground="#7D8B9E" Margin="10,0,0,10"/>
                                <UniformGrid Columns="2" Margin="0,0,0,25">
                                    <Button Content="A" Style="{StaticResource ConsolePrimaryBtn}" BorderBrush="#3DDB6E" Foreground="#3DDB6E" Margin="5" Height="45" Click="BtnMap_Click" Tag="A"/>
                                    <Button Content="B" Style="{StaticResource ConsoleDangerBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="B"/>
                                    <Button Content="X" Style="{StaticResource ConsoleInfoBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="X"/>
                                    <Button Content="Y" Style="{StaticResource ConsoleWarningBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="Y"/>
                                    <Button Content="LB" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="LeftShoulder"/>
                                    <Button Content="RB" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="RightShoulder"/>
                                    <Button Content="LT" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="LeftTrigger"/>
                                    <Button Content="RT" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="RightTrigger"/>
                                    <Button Content="L3" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="LeftThumb"/>
                                    <Button Content="R3" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="45" Click="BtnMap_Click" Tag="RightThumb"/>
                                </UniformGrid>
                                <TextBlock Text="D-PAD" FontSize="12" FontWeight="Bold" Foreground="#7D8B9E" Margin="10,0,0,10"/>
                                <UniformGrid Columns="2" Margin="0,0,0,20">
                                    <Button Content="↑" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="40" FontSize="16" Click="BtnMap_Click" Tag="DPadUp"/>
                                    <Button Content="↓" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="40" FontSize="16" Click="BtnMap_Click" Tag="DPadDown"/>
                                    <Button Content="←" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="40" FontSize="16" Click="BtnMap_Click" Tag="DPadLeft"/>
                                    <Button Content="→" Style="{StaticResource ConsoleGhostBtn}" Margin="5" Height="40" FontSize="16" Click="BtnMap_Click" Tag="DPadRight"/>
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="MAPPING DETAILS" FontSize="12" FontWeight="Black" Foreground="#E5B842" Margin="0,0,0,20" Effect="{StaticResource NeonGlow}"/>
                        <TextBlock x:Name="SelectedButtonText" Text="Select a button..." FontSize="20" FontWeight="Black" Margin="0,0,0,4" Foreground="#F0F4F8"/>
                        <TextBlock Text="🎮 Or press a button on your controller to auto-select"
                                   Foreground="#3A8EFF" FontSize="10" FontWeight="Bold"
                                   FontFamily="Consolas" Margin="0,0,0,16"/>
                        <ComboBox x:Name="ActionTypeCombo" Height="36" Style="{StaticResource DarkComboBox}" FontSize="14" SelectionChanged="ActionTypeCombo_SelectionChanged"><ComboBoxItem Content="Key Press" Tag="Key"/><ComboBoxItem Content="Left Click" Tag="LeftClick"/><ComboBoxItem Content="Right Click" Tag="RightClick"/><ComboBoxItem Content="Macro Playback" Tag="Macro"/><ComboBoxItem Content="Class Combo (Auto)" Tag="Combo"/><ComboBoxItem Content="🖥 Switch Window (Slave)" Tag="SwitchWindow"/></ComboBox>
                        <StackPanel x:Name="KeySelectionPanel" Margin="0,20,0,0">
                            <Button x:Name="BtnQuickBind" Content="⌨  PRESS A KEY"
                                    Height="44" FontSize="14" FontWeight="Black"
                                    Style="{StaticResource ConsoleGhostBtn}"
                                    BorderBrush="#3A8EFF" Foreground="#3A8EFF"
                                    Click="BtnQuickBind_Click" Margin="0,0,0,10"
                                    ToolTip="Click, then press any key on your keyboard to assign instantly"/>
                            <TextBlock x:Name="QuickBindHint" Text="— or pick from list —"
                                       Foreground="#3A4560" FontSize="10" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <ComboBox x:Name="KeyCombo" Height="36" FontSize="14" Style="{StaticResource DarkComboBox}"/>
                            <TextBlock Text="⌨ Press any key on keyboard to assign directly"
                                       Foreground="#3A8EFF" FontSize="10" FontWeight="Bold"
                                       Margin="0,8,0,0" FontFamily="Consolas"/>
                        </StackPanel>
                        <StackPanel x:Name="MacroSelectionPanel" Margin="0,20,0,0" Visibility="Collapsed"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36"><TextBox x:Name="MacroPathText" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" IsReadOnly="True" FontSize="13"/></Border><Button Grid.Column="1" Content="..." Width="45" Height="36" Style="{StaticResource ConsoleGhostBtn}" Margin="10,0,0,0" Click="BtnBrowseMacro_Click"/></Grid></StackPanel>
                        <StackPanel x:Name="WindowTargetPanel" Margin="0,20,0,0" Visibility="Collapsed">
                            <TextBlock Text="TARGET PROCESS NAME" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36">
                                <TextBox x:Name="WindowTargetText" Background="Transparent" Foreground="#E5B842" BorderThickness="0" Padding="10,8" FontSize="13" FontFamily="Consolas" FontWeight="Bold" Text="ragexe" ToolTip="Partial process name — 'ragexe' matches any ragexe*.exe"/>
                            </Border>
                            <TextBlock Text="Press button again to return to main client." Foreground="#7D8B9E" FontSize="10" Margin="0,6,0,0" FontStyle="Italic"/>
                        </StackPanel>
                        <CheckBox x:Name="TurboCheckbox" Content="Enable Turbo" Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,25,0,15" Checked="TurboCheckbox_Changed" Unchecked="TurboCheckbox_Changed"/>
                        <CheckBox x:Name="GroundSpellCheckbox" Content="Ground Spell (aim with RS)" Foreground="#F0F4F8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <StackPanel x:Name="TurboPanel" Visibility="Collapsed" Margin="0,10,0,0">
                            <ComboBox x:Name="TurboModeCombo" Height="36" FontSize="14" Style="{StaticResource DarkComboBox}">
                                <ComboBoxItem Content="Standard"/>
                                <ComboBoxItem Content="Burst"/>
                                <ComboBoxItem Content="Rhythmic"/>
                                <ComboBoxItem Content="Adaptive"/>
                            </ComboBox>
                            <Grid Margin="0,15,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36">
                                    <TextBox x:Name="TurboIntervalText" Text="100" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" FontSize="14"/>
                                </Border>
                                <Button Grid.Column="1" x:Name="BtnTurboTest" Content="▶ Test" Width="75" Height="36" Margin="10,0,0,0" Style="{StaticResource ConsoleGhostBtn}" Click="BtnTurboTest_Click"/>
                            </Grid>
                            <TextBlock x:Name="TurboFreqText" Text="" Foreground="#3A8EFF" FontSize="11" FontFamily="Consolas" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="APPLY MAPPING" Style="{StaticResource ConsolePrimaryBtn}" Height="40" Margin="0,30,0,10" Click="BtnApply_Click"/><Button Content="CLEAR MAPPING" Style="{StaticResource ConsoleDangerBtn}" Height="40" Click="BtnClear_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Grid.Row="2" Background="#07090D" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,12,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"><Button Content="SAVE &amp; CLOSE" Style="{StaticResource ConsolePrimaryBtn}" Width="160" Height="40" Margin="0,0,15,0" Click="BtnSave_Click"/><Button Content="CANCEL" Style="{StaticResource ConsoleGhostBtn}" Width="110" Height="40" Click="BtnCancel_Click"/></StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>