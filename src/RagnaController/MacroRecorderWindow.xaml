<Window x:Class="RagnaController.MacroRecorderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Recorder" Width="600" Height="550"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⏺" Foreground="#FF3A52" Margin="0,0,10,0" FontSize="14" Effect="{StaticResource NeonGlow}"/>
                        <TextBlock Text="MACRO RECORDER" FontWeight="Bold" FontSize="12" Foreground="#F0F4F8"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="MACRO NAME" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36">
                        <TextBox x:Name="MacroNameText" Text="Untitled Macro" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" VerticalContentAlignment="Center" FontSize="14"/>
                    </Border>
                </StackPanel>
            </Border>
            <Grid Grid.Row="2" Margin="20,0,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="BtnRecord" Content="● RECORD" Click="BtnRecord_Click" Width="110" Height="36" Style="{StaticResource ConsolePrimaryBtn}" Margin="0,0,10,0"/>
                    <Button x:Name="BtnStop" Content="■ STOP" Click="BtnStop_Click" Width="110" Height="36" Style="{StaticResource ConsoleDangerBtn}" IsEnabled="False" Margin="0,0,10,0"/>
                    <Button x:Name="BtnClear" Content="🗑 CLEAR" Click="BtnClear_Click" Width="110" Height="36" Style="{StaticResource ConsoleGhostBtn}"/>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                    <ListBox x:Name="StepsList" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" Padding="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <TextBlock Text="{Binding}" Foreground="#F0F4F8" FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
            <Border Grid.Row="3" Background="#07090D" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <TextBlock Text="Press Record and then hit your keys." Foreground="#7D8B9E" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="✏ Edit Saved Macro" Click="BtnEdit_Click" Style="{StaticResource ConsoleGhostBtn}" Width="150" Height="36" Margin="0,0,10,0"/>
                        <Button x:Name="BtnSave" Content="SAVE MACRO" Click="BtnSave_Click" Style="{StaticResource ConsolePrimaryBtn}" Width="130" Height="36" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>