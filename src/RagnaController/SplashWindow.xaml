<Window x:Class="RagnaController.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="780" Height="800"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Resources>

        <!-- ① Fenster einblenden -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.7">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ② Logo springt ein mit elastischem Scale-Pop -->
        <Storyboard x:Key="LogoIn">
            <DoubleAnimation Storyboard.TargetName="LogoImage"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.9">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.80" To="1.0" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.80" To="1.0" Duration="0:0:1.0">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ③ Goldener Außenring pulsiert (Loop) -->
        <Storyboard x:Key="GoldPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GoldRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.80" Duration="0:0:2.0">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GoldRing"
                             Storyboard.TargetProperty="Width"
                             From="440" To="560" Duration="0:0:2.0">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GoldRing"
                             Storyboard.TargetProperty="Height"
                             From="440" To="560" Duration="0:0:2.0">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ④ Innerer Kern-Glow (Loop) -->
        <Storyboard x:Key="CoreGlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="CoreGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.18" To="0.55" Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CoreGlow"
                             Storyboard.TargetProperty="Width"
                             From="220" To="360" Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CoreGlow"
                             Storyboard.TargetProperty="Height"
                             From="220" To="360" Duration="0:0:1.6">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑤ Blauer Controller-Blitz (einmalig) -->
        <Storyboard x:Key="BlueFlash">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BlueGlow"
                                          Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0.90">
                    <EasingDoubleKeyFrame.EasingFunction><CubicEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.45"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- ⑤b Blauer Glow pulsiert dauerhaft (Loop) -->
        <Storyboard x:Key="BluePulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BlueGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.28" To="0.60" Duration="0:0:2.4">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑥ Logo schwebt auf/ab (Loop) -->
        <Storyboard x:Key="LogoFloat" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoTranslate"
                             Storyboard.TargetProperty="Y"
                             From="-6" To="6" Duration="0:0:2.8">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑦ Lichtstrahl von oben (einmalig) -->
        <Storyboard x:Key="BeamIn">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LightBeam"
                                          Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.70">
                    <EasingDoubleKeyFrame.EasingFunction><CubicEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:2.0" Value="0.22"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- ⑦b Strahl atmet leicht (Loop) -->
        <Storyboard x:Key="BeamPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LightBeam"
                             Storyboard.TargetProperty="Opacity"
                             From="0.14" To="0.32" Duration="0:0:3.2">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑧ Logo-Glow der DropShadow atmet (Loop) — extra warm auf freigestelltem Bild -->
        <Storyboard x:Key="LogoGlowPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="LogoImage"
                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                             From="30" To="65" Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoImage"
                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                             From="0.28" To="0.65" Duration="0:0:2.2">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑨ Flügel-Glows einblenden -->
        <Storyboard x:Key="WingsIn">
            <DoubleAnimation Storyboard.TargetName="WingLeft"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.55" Duration="0:0:1.2"/>
            <DoubleAnimation Storyboard.TargetName="WingRight"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.55" Duration="0:0:1.2"/>
        </Storyboard>

        <!-- ⑩ Flügel-Glows pulsieren (Loop) -->
        <Storyboard x:Key="WingsPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="WingLeft"
                             Storyboard.TargetProperty="Opacity"
                             From="0.30" To="0.65" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="WingRight"
                             Storyboard.TargetProperty="Opacity"
                             From="0.45" To="0.70" Duration="0:0:2.5">
                <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ⑪ Partikel aufsteigend (Loop) -->
        <Storyboard x:Key="ParticlesIn">
            <DoubleAnimation Storyboard.TargetName="P1"   Storyboard.TargetProperty="Opacity" From="0" To="0.90" Duration="0:0:0.4" BeginTime="0:0:0.1" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P1T"  Storyboard.TargetProperty="Y"       From="0" To="-40"  Duration="0:0:3.2" BeginTime="0:0:0.1" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P2"   Storyboard.TargetProperty="Opacity" From="0" To="0.75" Duration="0:0:0.5" BeginTime="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P2T"  Storyboard.TargetProperty="Y"       From="0" To="-52"  Duration="0:0:4.1" BeginTime="0:0:0.5" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P3"   Storyboard.TargetProperty="Opacity" From="0" To="1.00" Duration="0:0:0.3" BeginTime="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P3T"  Storyboard.TargetProperty="Y"       From="0" To="-32"  Duration="0:0:2.8" BeginTime="0:0:0.8" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P4"   Storyboard.TargetProperty="Opacity" From="0" To="0.80" Duration="0:0:0.4" BeginTime="0:0:0.2" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P4T"  Storyboard.TargetProperty="Y"       From="0" To="-46"  Duration="0:0:3.7" BeginTime="0:0:0.2" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P5"   Storyboard.TargetProperty="Opacity" From="0" To="0.85" Duration="0:0:0.5" BeginTime="0:0:1.0" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P5T"  Storyboard.TargetProperty="Y"       From="0" To="-30"  Duration="0:0:2.5" BeginTime="0:0:1.0" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P6"   Storyboard.TargetProperty="Opacity" From="0" To="0.95" Duration="0:0:0.3" BeginTime="0:0:0.6" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P6T"  Storyboard.TargetProperty="Y"       From="0" To="-36"  Duration="0:0:3.0" BeginTime="0:0:0.6" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P7"   Storyboard.TargetProperty="Opacity" From="0" To="0.70" Duration="0:0:0.4" BeginTime="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P7T"  Storyboard.TargetProperty="Y"       From="0" To="-48"  Duration="0:0:4.5" BeginTime="0:0:1.2" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P8"   Storyboard.TargetProperty="Opacity" From="0" To="0.95" Duration="0:0:0.3" BeginTime="0:0:0.3" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P8T"  Storyboard.TargetProperty="Y"       From="0" To="-26"  Duration="0:0:2.2" BeginTime="0:0:0.3" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P9"   Storyboard.TargetProperty="Opacity" From="0" To="0.80" Duration="0:0:0.5" BeginTime="0:0:0.9" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P9T"  Storyboard.TargetProperty="Y"       From="0" To="-40"  Duration="0:0:3.4" BeginTime="0:0:0.9" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P10"  Storyboard.TargetProperty="Opacity" From="0" To="0.75" Duration="0:0:0.4" BeginTime="0:0:1.4" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P10T" Storyboard.TargetProperty="Y"       From="0" To="-58"  Duration="0:0:4.8" BeginTime="0:0:1.4" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P11"  Storyboard.TargetProperty="Opacity" From="0" To="1.00" Duration="0:0:0.3" BeginTime="0:0:0.4" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P11T" Storyboard.TargetProperty="Y"       From="0" To="-22"  Duration="0:0:2.0" BeginTime="0:0:0.4" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P12"  Storyboard.TargetProperty="Opacity" From="0" To="0.85" Duration="0:0:0.4" BeginTime="0:0:1.5" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="P12T" Storyboard.TargetProperty="Y"       From="0" To="-44"  Duration="0:0:3.8" BeginTime="0:0:1.5" RepeatBehavior="Forever"/>
        </Storyboard>

        <!-- ⑫ Progress-Bar -->
        <Storyboard x:Key="ProgressAnim">
            <DoubleAnimation Storyboard.TargetName="ProgressBar"
                             Storyboard.TargetProperty="Width"
                             From="0" To="440" Duration="0:0:4.2"/>
        </Storyboard>

        <!-- ⑬ Bottom-Row einblenden -->
        <Storyboard x:Key="BottomIn">
            <DoubleAnimation Storyboard.TargetName="BottomRow"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.8"/>
        </Storyboard>

    </Window.Resources>

    <!-- ═══ ROOT — vollständig transparent, kein Hintergrund ════════════ -->
    <Border x:Name="Root" Opacity="0" Background="Transparent">
        <Grid>

            <!-- ── Großer äußerer Ambient-Glow (sehr weich, kaum sichtbar) ── -->
            <Ellipse Width="740" Height="740"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-30,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#00000000" Offset="0.45"/>
                        <GradientStop Color="#14D4A832" Offset="0.70"/>
                        <GradientStop Color="#22E8C040" Offset="0.82"/>
                        <GradientStop Color="#0CD4A832" Offset="0.93"/>
                        <GradientStop Color="#00000000" Offset="1.00"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Goldener pulsierender Außenring ── -->
            <Ellipse x:Name="GoldRing"
                     Width="440" Height="440" Opacity="0"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-30,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#00000000" Offset="0.54"/>
                        <GradientStop Color="#55D4A832" Offset="0.74"/>
                        <GradientStop Color="#88FFD840" Offset="0.84"/>
                        <GradientStop Color="#44D4A832" Offset="0.94"/>
                        <GradientStop Color="#00000000" Offset="1.00"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Innerer Kern-Glow (goldweiß, hinter Charakter-Mitte) ── -->
            <Ellipse x:Name="CoreGlow"
                     Width="240" Height="240" Opacity="0"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="0,-80,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#60FFF0B0" Offset="0"/>
                        <GradientStop Color="#38D4A832" Offset="0.45"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Blauer Controller-Glow von unten ── -->
            <Ellipse x:Name="BlueGlow"
                     Width="660" Height="320" Opacity="0"
                     HorizontalAlignment="Center" VerticalAlignment="Bottom"
                     Margin="0,0,0,55" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,0.08"
                                         Center="0.5,0.08"
                                         RadiusX="0.5" RadiusY="0.92">
                        <GradientStop Color="#CC00C8FF" Offset="0"/>
                        <GradientStop Color="#550058CC" Offset="0.40"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Göttlicher Lichtstrahl von oben ── -->
            <Rectangle x:Name="LightBeam"
                       Width="200" Opacity="0"
                       HorizontalAlignment="Center" VerticalAlignment="Top"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#EEFFF5B0" Offset="0"/>
                        <GradientStop Color="#99FFE870" Offset="0.20"/>
                        <GradientStop Color="#33FFD040" Offset="0.55"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- ── Linker Flügel-Glow (warm-gold, passend zum freigest. Logo) ── -->
            <Ellipse x:Name="WingLeft"
                     Width="300" Height="230" Opacity="0"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="0,80,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.8,0.5" Center="0.8,0.5"
                                         RadiusX="0.8" RadiusY="0.7">
                        <GradientStop Color="#55FFE8A0" Offset="0"/>
                        <GradientStop Color="#22D4A832" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Rechter Flügel-Glow ── -->
            <Ellipse x:Name="WingRight"
                     Width="300" Height="230" Opacity="0"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,80,0,0" IsHitTestVisible="False">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.2,0.5" Center="0.2,0.5"
                                         RadiusX="0.8" RadiusY="0.7">
                        <GradientStop Color="#55FFE8A0" Offset="0"/>
                        <GradientStop Color="#22D4A832" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- ── Partikel-Canvas ── -->
            <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    IsHitTestVisible="False">
                <!-- Gold links -->
                <Ellipse x:Name="P1"  Canvas.Left="110" Canvas.Top="360" Width="5" Height="5" Fill="#FFD060" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P1T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P2"  Canvas.Left="165" Canvas.Top="290" Width="4" Height="4" Fill="#FFB800" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P2T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="1.5"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P3"  Canvas.Left="68"  Canvas.Top="430" Width="6" Height="6" Fill="#D4A832" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P3T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2.5"/></Ellipse.Effect></Ellipse>
                <!-- Gold rechts -->
                <Ellipse x:Name="P4"  Canvas.Left="610" Canvas.Top="340" Width="5" Height="5" Fill="#FFD060" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P4T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P5"  Canvas.Left="670" Canvas.Top="410" Width="4" Height="4" Fill="#C8A020" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P5T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="1.5"/></Ellipse.Effect></Ellipse>
                <!-- Blau (Controller) -->
                <Ellipse x:Name="P6"  Canvas.Left="215" Canvas.Top="590" Width="5" Height="5" Fill="#40CCFF" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P6T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2.5"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P7"  Canvas.Left="556" Canvas.Top="570" Width="6" Height="6" Fill="#20AAFF" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P7T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect></Ellipse>
                <!-- Weiß-gold Flügel oben -->
                <Ellipse x:Name="P8"  Canvas.Left="190" Canvas.Top="175" Width="4" Height="4" Fill="#FFFFC0" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P8T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="1.5"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P9"  Canvas.Left="575" Canvas.Top="195" Width="5" Height="5" Fill="#FFE890" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P9T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P10" Canvas.Left="375" Canvas.Top="102" Width="4" Height="4" Fill="#FFD860" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P10T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="1.5"/></Ellipse.Effect></Ellipse>
                <!-- Extra -->
                <Ellipse x:Name="P11" Canvas.Left="325" Canvas.Top="608" Width="4" Height="4" Fill="#80D8FF" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P11T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect></Ellipse>
                <Ellipse x:Name="P12" Canvas.Left="445" Canvas.Top="255" Width="5" Height="5" Fill="#FFE060" Opacity="0"><Ellipse.RenderTransform><TranslateTransform x:Name="P12T"/></Ellipse.RenderTransform><Ellipse.Effect><BlurEffect Radius="2"/></Ellipse.Effect></Ellipse>
            </Canvas>

            <!-- ── LOGO (freigestellt, transparent, mit Gold-DropShadow) ── -->
            <Image x:Name="LogoImage"
                   Source="/Assets/splash_logo.png"
                   Width="700"
                   Opacity="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Margin="0,-30,0,75"
                   Stretch="Uniform"
                   RenderTransformOrigin="0.5,0.5"
                   IsHitTestVisible="False">
                <Image.Effect>
                    <!-- Gold-Glow passend zum goldenen Rahmen im Artwork -->
                    <DropShadowEffect Color="#D4A832" BlurRadius="40"
                                      ShadowDepth="0" Opacity="0.40"/>
                </Image.Effect>
                <Image.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="LogoTranslate"/>
                    </TransformGroup>
                </Image.RenderTransform>
            </Image>

            <!-- ── Progress + Status unten (über transparentem Hintergrund) ── -->
            <StackPanel x:Name="BottomRow"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16"
                        Width="460"
                        Opacity="0">

                <TextBlock x:Name="StatusText"
                           Text="Initializing…"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Foreground="#99D4A832"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <Grid Height="4">
                    <Rectangle RadiusX="2" RadiusY="2" Opacity="0.25">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#44D4A832" Offset="0"/>
                                <GradientStop Color="#22886010" Offset="0.5"/>
                                <GradientStop Color="#44D4A832" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle x:Name="ProgressBar"
                               Width="0" HorizontalAlignment="Left"
                               RadiusX="2" RadiusY="2">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#7A5000" Offset="0"/>
                                <GradientStop Color="#D4A832" Offset="0.55"/>
                                <GradientStop Color="#FFE870" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                        <Rectangle.Effect>
                            <DropShadowEffect Color="#FFE060" BlurRadius="10"
