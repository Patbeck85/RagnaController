<Window x:Class="RagnaController.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Width="780" Height="800"
        Topmost="True" ShowInTaskbar="False">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.7"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="LogoIn">
            <DoubleAnimation Storyboard.TargetName="LogoImage" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.9"/>
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX" From="0.8" To="1.0" Duration="0:0:1.0"><DoubleAnimation.EasingFunction><ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY" From="0.8" To="1.0" Duration="0:0:1.0"><DoubleAnimation.EasingFunction><ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="GoldPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GoldRing" Storyboard.TargetProperty="Opacity" From="0.35" To="0.85" Duration="0:0:2.0"/>
            <DoubleAnimation Storyboard.TargetName="GoldRing" Storyboard.TargetProperty="Width" From="440" To="580" Duration="0:0:2.0"/>
            <DoubleAnimation Storyboard.TargetName="GoldRing" Storyboard.TargetProperty="Height" From="440" To="580" Duration="0:0:2.0"/>
        </Storyboard>
        <Storyboard x:Key="ProgressAnim">
            <DoubleAnimation Storyboard.TargetName="ProgressBar" Storyboard.TargetProperty="Width" From="0" To="460" Duration="0:0:4.2"/>
        </Storyboard>
    </Window.Resources>
    <Border x:Name="Root" Opacity="0" Background="Transparent">
        <Grid>
            <Ellipse x:Name="GoldRing" Width="440" Height="440" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-30,0,0">
                <Ellipse.Fill><RadialGradientBrush><GradientStop Color="#00000000" Offset="0.54"/><GradientStop Color="#66E5B842" Offset="0.74"/><GradientStop Color="#AAE5B842" Offset="0.84"/><GradientStop Color="#00000000" Offset="1.0"/></RadialGradientBrush></Ellipse.Fill>
            </Ellipse>
            <Image x:Name="LogoImage" Source="/Assets/splash_logo.png" Width="700" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-30,0,75">
                <Image.Effect><DropShadowEffect Color="#E5B842" BlurRadius="50" ShadowDepth="0" Opacity="0.5"/></Image.Effect>
                <Image.RenderTransform><TransformGroup><ScaleTransform x:Name="LogoScale"/><TranslateTransform x:Name="LogoTranslate"/></TransformGroup></Image.RenderTransform>
            </Image>
            <StackPanel x:Name="BottomRow" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" Width="480" Opacity="0">
                <TextBlock x:Name="StatusText" Text="Initializing…" FontSize="12" FontWeight="Bold" Foreground="#E5B842" HorizontalAlignment="Center" Margin="0,0,0,10" Effect="{StaticResource NeonGlow}"/>
                <Grid Height="4">
                    <Rectangle RadiusX="2" RadiusY="2" Opacity="0.2" Fill="#E5B842"/>
                    <Rectangle x:Name="ProgressBar" Width="0" HorizontalAlignment="Left" RadiusX="2" RadiusY="2" Fill="#E5B842">
                        <Rectangle.Effect><DropShadowEffect Color="#E5B842" BlurRadius="10" ShadowDepth="0"/></Rectangle.Effect>
                    </Rectangle>
                </Grid>
                <TextBlock x:Name="SplashVersionLabel" Text="v1.2.0" FontSize="10" FontWeight="Bold" Foreground="#A1B0C5" HorizontalAlignment="Right" Margin="0,6,2,0"/>
            </StackPanel>
            <MediaElement x:Name="VoicePlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Visibility="Collapsed" Volume="1.0"/>
        </Grid>
    </Border>
</Window>