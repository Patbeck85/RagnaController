<Window x:Class="RagnaController.RadialSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Radial Menu Setup" Width="720" Height="760"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🎯" Foreground="#E5B842" Margin="0,0,10,0" FontSize="16" Effect="{StaticResource NeonGlow}"/>
                        <TextBlock Text="RADIAL MENU SETUP" FontWeight="Bold" FontSize="13" Foreground="#F0F4F8"/>
                    </StackPanel>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Padding="20">
                <StackPanel>
                    <TextBlock Foreground="#A1B0C5" FontSize="12" TextWrapping="Wrap" LineHeight="18" FontWeight="SemiBold">
                        <Run Text="Trigger: Hold "/>
                        <Run Foreground="#E5B842" FontWeight="Black" Text="LT + RT"/>
                        <Run Text=" simultaneously → Aim Right Stick → Release triggers to execute."/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Grid Grid.Row="2" Margin="20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="#1A2030">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="#" Foreground="#E5B842" FontWeight="Black" FontSize="11" VerticalAlignment="Center" Margin="15,0"/>
                    <TextBlock Grid.Column="1" Text="DISPLAY NAME" Foreground="#7D8B9E" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" Margin="10,0"/>
                    <TextBlock Grid.Column="2" Text="COMMAND / CHAT" Foreground="#7D8B9E" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" Margin="10,0"/>
                    <TextBlock Grid.Column="3" Text="KEY BINDING" Foreground="#7D8B9E" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" Margin="10,0"/>
                    <TextBlock Grid.Column="4" Text="EMOTES" Foreground="#E5B842" FontWeight="Bold" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ItemsStack" Margin="0,10,0,0"/>
                </ScrollViewer>
            </Grid>
            <Border Grid.Row="3" Background="#07090D" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <TextBlock Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="Leave blank to disable a slot. "/>
                        <Run Foreground="#E5B842" Text="8 Slots"/>
                        <Run Text=" = 8 directions."/>
                    </TextBlock>
                    <Button Content="SAVE RADIAL" Click="BtnSave_Click" Style="{StaticResource ConsolePrimaryBtn}" HorizontalAlignment="Right" Width="140" Height="36"/>
                </Grid>
            </Border>
            <Grid x:Name="EmoteGalleryOverlay" Grid.RowSpan="4" Background="#E6080A0F" Visibility="Collapsed">
                <Border Background="#121620" BorderBrush="#E5B842" BorderThickness="1" CornerRadius="12" Width="640" Height="640" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#E5B842" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="SELECT EMOTE" Foreground="#F0F4F8" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                            <Button Content="✕" Click="BtnCloseGallery_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14" FontWeight="Bold"/>
                        </Grid>

                        <!-- Status + Buttons -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="EmoteStatusText"
                                       Grid.Column="0"
                                       Text="Emoji-Fallback aktiv"
                                       Foreground="#7D8B9E" FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="⬇ iROWiki laden"
                                    Click="BtnDownloadWiki_Click"
                                    Style="{StaticResource ConsolePrimaryBtn}"
                                    Height="30" Padding="10,0" Margin="0,0,6,0"
                                    FontSize="11"/>
                            <Button Grid.Column="2"
                                    Content="📁 Scan RO Client"
                                    Click="BtnScanRoPath_Click"
                                    Style="{StaticResource ConsoleGhostBtn}"
                                    Height="30" Padding="10,0"
                                    FontSize="11"/>
                        </Grid>

                        <!-- Emote-Galerie -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">
                            <ItemsControl x:Name="EmoteList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="4" Width="96" Height="88"
                                                Style="{StaticResource ConsoleGhostBtn}"
                                                Click="BtnSelectEmote_Click" Tag="{Binding}">
                                            <StackPanel VerticalAlignment="Center">
                                                <!-- Echtes Bild wenn vorhanden -->
                                                <Image Source="{Binding ImagePath}"
                                                       Visibility="{Binding ImageVisibility}"
                                                       Width="36" Height="36" Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                       Margin="0,0,0,4"/>
                                                <!-- Emoji-Fallback wenn kein Bild -->
                                                <TextBlock Text="{Binding FallbackEmoji}"
                                                           Visibility="{Binding EmojiVisibility}"
                                                           FontSize="26" HorizontalAlignment="Center"
                                                           Margin="0,0,0,4" LineHeight="32"/>
                                                <TextBlock Text="{Binding Command}"
                                                           FontSize="11" Foreground="#E5B842"
                                                           FontWeight="Bold" HorizontalAlignment="Center"
                                                           FontFamily="Consolas"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="9" Foreground="#7D8B9E"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>