<Window x:Class="RagnaController.ProfileWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wizard" Width="600" Height="550"
        Background="Transparent" WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterOwner" MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#080A0F" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="45"/><RowDefinition Height="*"/><RowDefinition Height="60"/></Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="#2A3245" BorderThickness="0,0,0,1">
                <Grid Margin="15,0">
                    <TextBlock Text="PROFILE WIZARD" FontWeight="Bold" FontSize="12" Foreground="#E5B842" VerticalAlignment="Center" Effect="{StaticResource NeonGlow}"/>
                    <Button Content="✕" Click="BtnCancel_Click" HorizontalAlignment="Right" Width="30" Height="30" Background="Transparent" BorderThickness="0" Foreground="#A1B0C5" FontSize="14"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="25">
                <StackPanel x:Name="Step1Panel">
                    <TextBlock Text="PROFILE NAME" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                    <Border Background="#121620" BorderBrush="#2A3245" BorderThickness="1" CornerRadius="6" Height="36">
                        <TextBox x:Name="ProfileNameText" Background="Transparent" Foreground="#F0F4F8" BorderThickness="0" Padding="10,8" VerticalContentAlignment="Center" FontSize="14"/>
                    </Border>
                    <TextBlock Text="CLASS" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,20,0,8"/>
                    <ComboBox x:Name="ClassCombo" Style="{StaticResource DarkComboBox}" Height="36" FontSize="14" SelectionChanged="ClassCombo_SelectionChanged">
                        <ComboBoxItem Content="Melee" Tag="Melee"/><ComboBoxItem Content="Mage" Tag="Mage"/><ComboBoxItem Content="Ranged" Tag="Ranged"/><ComboBoxItem Content="Support" Tag="Support"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel x:Name="Step2Panel" Visibility="Collapsed">
                    <TextBlock Text="COMBAT ENGINES" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                    <CheckBox x:Name="EnableMeleeCheck" Content="Enable Auto-Target" Foreground="#F0F4F8" FontSize="14" Margin="0,0,0,15"/>
                    <CheckBox x:Name="EnableKiteCheck" Content="Enable Kite Engine" Foreground="#F0F4F8" FontSize="14" Margin="0,0,0,15"/>
                    <CheckBox x:Name="EnableMageCheck" Content="Enable Mage System" Foreground="#F0F4F8" FontSize="14" Margin="0,0,0,15"/>
                    <CheckBox x:Name="EnableSupportCheck" Content="Enable Support Mode" Foreground="#F0F4F8" FontSize="14" Margin="0,0,0,15"/>
                </StackPanel>
                <StackPanel x:Name="Step3Panel" Visibility="Collapsed">
                    <TextBlock Text="QUICK KEYS" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,15"/>
                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="A:" Foreground="#E5B842" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/><ComboBox x:Name="AButtonCombo" Grid.Column="1" Style="{StaticResource DarkComboBox}" Height="36"/></Grid>
                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="B:" Foreground="#FF3A52" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/><ComboBox x:Name="BButtonCombo" Grid.Column="1" Style="{StaticResource DarkComboBox}" Height="36"/></Grid>
                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="X:" Foreground="#3A8EFF" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/><ComboBox x:Name="XButtonCombo" Grid.Column="1" Style="{StaticResource DarkComboBox}" Height="36"/></Grid>
                    <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Y:" Foreground="#E5B842" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/><ComboBox x:Name="YButtonCombo" Grid.Column="1" Style="{StaticResource DarkComboBox}" Height="36"/></Grid>
                </StackPanel>
                <StackPanel x:Name="Step4Panel" Visibility="Collapsed">
                    <TextBlock Text="REVIEW" Foreground="#7D8B9E" FontSize="10" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Border Style="{StaticResource CardBorder}" Padding="20">
                        <StackPanel>
                            <TextBlock x:Name="ReviewName" Foreground="#E5B842" FontSize="22" FontWeight="Black" Margin="0,0,0,5" Effect="{StaticResource NeonGlow}"/>
                            <TextBlock x:Name="ReviewClass" Foreground="#A1B0C5" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                            <TextBlock Text="The profile will be created with default movement settings. You can tweak everything later." Foreground="#7D8B9E" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            <Border Grid.Row="2" Background="#07090D" BorderBrush="#2A3245" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,0">
                <Grid VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="Step1Dot" Width="10" Height="10" Fill="#E5B842" Margin="0,0,8,0" Effect="{StaticResource NeonGlow}"/><Ellipse x:Name="Step2Dot" Width="10" Height="10" Fill="#2A3245" Margin="0,0,8,0"/><Ellipse x:Name="Step3Dot" Width="10" Height="10" Fill="#2A3245" Margin="0,0,8,0"/><Ellipse x:Name="Step4Dot" Width="10" Height="10" Fill="#2A3245"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnBack" Content="BACK" Click="BtnBack_Click" Style="{StaticResource ConsoleGhostBtn}" Width="90" Height="36" Margin="0,0,10,0" IsEnabled="False"/>
                        <Button x:Name="BtnNext" Content="NEXT" Click="BtnNext_Click" Style="{StaticResource ConsolePrimaryBtn}" Width="110" Height="36"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>